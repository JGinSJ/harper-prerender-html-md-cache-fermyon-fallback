{
  "compilerOptions": {
    // Specify ECMAScript target version
    "target": "ES2020",
    // Specify module code generation
    "module": "ES2022",
    // Enable all strict type-checking options
    "strict": true,
    // Enable compatibility with CommonJS and ES Modules
    "esModuleInterop": true,
    // Skip type checking of declaration files
    "skipLibCheck": true,
    // Ensure consistent casing in file names
    "forceConsistentCasingInFileNames": true,
    // Redirect output structure to the 'dist' directory
    "outDir": "./dist",
    // Specify the root directory of input files
    "rootDir": "./src",
    // Allow importing .json files
    "resolveJsonModule": true,
    // Use Node.js module resolution strategy
    "moduleResolution": "node",
    // Allow JavaScript files to be compiled
    "allowJs": true,
    // Raise error on expressions and declarations with an implied 'any' type
    "noImplicitAny": true
  }
}

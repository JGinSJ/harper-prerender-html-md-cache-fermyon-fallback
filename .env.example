# Harper HTML+Markdown Prerender — configuration reference
#
# The EdgeWorker reads PMUSER_* values from Akamai property variables at runtime
# (Control Center → Property Manager → Property Variables). No secrets appear
# in the bundle or in git.
#
# Copy this file to .env for local tooling (bulk-upload script, mock server).
# .env is excluded from git.

# ── Akamai property variables (set in Control Center, not here) ───────────────
# PMUSER_HARPER_ENABLED    true
# PMUSER_HARPER_URL        https://your-harper-app-url      ← Harper delivery base URL (no trailing slash)
# PMUSER_HARPER_TOKEN      your-harper-jwt-token            ← mark Sensitive (legacy Bearer auth)
# PMUSER_HARPER_BOT_KEY    your-bot-routing-secret          ← mark Sensitive; sent as the x-pr-req-key
#                                                             header the component validates
#                                                             (BOT_REQUEST_KEY). Defaults to PMUSER_HARPER_TOKEN.
# PMUSER_HARPER_TIMEOUT_MS 1500
# PMUSER_WASM_URL          https://your-fermyon-app.fwf.app  ← optional; overrides the default
#                                                              Fermyon HTML→Markdown fallback endpoint
# PMUSER_AI_CRAWLER_UAS    gptbot,oai-searchbot,claudebot,perplexitybot,...
#                          ← optional override of the built-in AI-crawler User-Agent list.
#                            A request is routed to the Markdown path if its UA matches one of
#                            these OR it sends `Accept: text/markdown`; everything else
#                            (humans + SEO crawlers) gets prerendered HTML.

# ── Local tooling only (bulk-upload script and mock server) ───────────────────
HARPER_ENABLED=false
HARPER_OPS_URL=https://gq4-your-node.harperfabric.com  # Harper HTTP app port (e.g. :9926) — POSTs to /sitemaps
HARPER_ADMIN_USER=your-harper-admin-user               # HarperDB username (Basic auth)
HARPER_ADMIN_PASS=your-harper-admin-password           # HarperDB password
HARPER_TIMEOUT_MS=1500

# ── Harper component (harper-prerender/) — set in the component env or compose ─
# BOT_REQUEST_KEY_NAME     x-pr-req-key   # header the /page and /page_content endpoints check
# BOT_REQUEST_KEY          <secret>       # value the header must equal (empty/unset = open, dev only)

# ── Demo UI (demo-ui/server.js) — all optional, sane defaults baked in ─────────
# PORT=8080                                # demo UI port
# PRODUCTION_HOST=nobodycaresworkharder.me # edge host the 3-scenario flow runs against
# WASM_URL=https://your-fermyon-app.fwf.app# Fermyon endpoint used for token comparison
# HARPER_PREVIEW_URL=http://localhost:9926 # Harper instance the Render Lab calls (/render_preview, /cache_clear)
# HARPER_BOT_KEY=                          # x-pr-req-key value the Render Lab sends to Harper
